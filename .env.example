# =========================================================
# Microsoft Bookings / Teams scheduler — environment config
# Copy this file to ".env" and fill in real values.
# NEVER commit the real .env (it is git-ignored).
# =========================================================

# ---------------------------------------------------------
# 1) Azure AD app registration (Entra ID)
#    Portal: https://entra.microsoft.com  ->  App registrations  ->  New registration
#    Use the "Client credentials" (app-only) flow.
# ---------------------------------------------------------

# Directory (tenant) ID — found on the app's Overview page.
MS_TENANT_ID=00000000-0000-0000-0000-000000000000

# Application (client) ID — found on the app's Overview page.
MS_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Client secret VALUE (not the Secret ID).
# Certificates & secrets -> New client secret. Copy the "Value" immediately.
MS_CLIENT_SECRET=your-client-secret-value

# ---------------------------------------------------------
# 2) Microsoft Graph API permissions (admin consent required)
#    On the app:  API permissions -> Add a permission -> Microsoft Graph
#    -> Application permissions -> add the scopes below -> "Grant admin consent".
#
#      Bookings.ReadWrite.All        (read availability + create appointments)
#      BookingsAppointment.ReadWrite.All
#
#    No extra value goes here — this is a reminder of what to grant.
#    The server requests the ".default" scope automatically.
# ---------------------------------------------------------
MS_GRAPH_SCOPE=https://graph.microsoft.com/.default

# ---------------------------------------------------------
# 3) Microsoft Bookings business + service
#    Create a Bookings calendar at https://outlook.office.com/bookings
#    Enable Teams online meetings on the service you book.
# ---------------------------------------------------------

# The Bookings business ID. This is usually the booking mailbox SMTP address,
# e.g. "RuarkIndustries@yourdomain.onmicrosoft.com".
# List them via Graph: GET https://graph.microsoft.com/v1.0/solutions/bookingBusinesses
MS_BOOKINGS_BUSINESS_ID=YourBusiness@yourtenant.onmicrosoft.com

# The service that gets booked (e.g. "Consultation").
# List via: GET /solutions/bookingBusinesses/{id}/services
MS_BOOKINGS_SERVICE_ID=

# The staff member (you) the appointment is assigned to, used for availability.
# List via: GET /solutions/bookingBusinesses/{id}/staffMembers
MS_BOOKINGS_STAFF_ID=

# ---------------------------------------------------------
# 4) Scheduling window (drives the generated slots)
#    Slots are generated on every :00 and :30 between open and close.
# ---------------------------------------------------------
BUSINESS_TIMEZONE=America/New_York
BUSINESS_OPEN_HOUR=8         # 8 AM
BUSINESS_CLOSE_HOUR=17       # 5 PM (24h clock)
SLOT_INTERVAL_MINUTES=30     # a slot every :00 and :30
SLOT_DURATION_MINUTES=30     # length of each meeting

# ---------------------------------------------------------
# 5) Server
# ---------------------------------------------------------
PORT=3000
# Comma-separated origins allowed to call the API (CORS).
# Leave blank when the Express server also serves the static site (same origin).
ALLOWED_ORIGINS=
